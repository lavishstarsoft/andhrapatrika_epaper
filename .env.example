# Copy to .env.production on the Hetzner server (never commit real values)
# cp .env.example .env.production

# Site URL (must match your domain — used by NextAuth + SEO)
NEXTAUTH_URL=https://www.andhrapatrikaa.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# MongoDB Atlas or self-hosted MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# Cloudflare R2 (same bucket as dev, or a separate bucket for production)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=https://your-r2-public-url.example.com
